{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "questionTypesSmoke"
  ],
  "properties": {
    "questionTypesSmoke": {
      "type": "object",
      "required": [
        "stringValue",
        "enumValue",
        "booleanValue",
        "intValue",
        "listValue",
        "image"
      ],
      "properties": {
        "stringValue": {
          "type": "string"
        },
        "enumValue": {
          "type": "string",
          "enum": [
            "option-a",
            "option-b",
            "option-c"
          ]
        },
        "booleanValue": {
          "type": "boolean"
        },
        "intValue": {
          "type": "integer"
        },
        "listValue": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "image": {
          "type": "object",
          "required": [
            "repository",
            "tag",
            "pullPolicy"
          ],
          "properties": {
            "repository": {
              "type": "string"
            },
            "tag": {
              "type": "string"
            },
            "pullPolicy": {
              "type": "string",
              "enum": [
                "Always",
                "IfNotPresent",
                "Never"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
